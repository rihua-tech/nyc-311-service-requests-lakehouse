{
  "triggers": [
    {
      "name": "tg_nyc311_daily_ingest",
      "type": "ScheduleTrigger",
      "runtimeState": "Stopped",
      "properties": {
        "description": "Starter recurring trigger definition for daily NYC 311 raw landing with downstream Databricks handoff.",
        "pipelines": [
          {
            "pipelineReference": {
              "referenceName": "pl_nyc311_ingest",
              "type": "PipelineReference"
            },
            "parameters": {
              "environment": "dev",
              "catalog": "spark_catalog",
              "run_date": "@{formatDateTime(addDays(trigger().scheduledTime,-1),'yyyy-MM-dd')}",
              "window_start": "@{concat(formatDateTime(addDays(trigger().scheduledTime,-1),'yyyy-MM-dd'),'T00:00:00')}",
              "window_end": "@{concat(formatDateTime(trigger().scheduledTime,'yyyy-MM-dd'),'T00:00:00')}",
              "page_size": 1000,
              "batch_id": "@{concat('adf-',formatDateTime(trigger().scheduledTime,'yyyyMMddHHmm'))}"
            }
          }
        ],
        "recurrence": {
          "frequency": "Day",
          "interval": 1,
          "timeZone": "Eastern Standard Time",
          "schedule": {
            "hours": [
              1
            ],
            "minutes": [
              15
            ]
          }
        }
      },
      "notes": "Starter schedule only. It documents the Milestone 11 cadence and parameters but does not mean the trigger is deployed or active."
    }
  ]
}
